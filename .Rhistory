test = list(t.test(nota_pos~origen,var.equal=TRUE) |> tidy())
) |>
unnest(test) |>
# Opcional: Seleccionamos lo más relevante para su informe
select(origen, estimate, p.value, conf.low, conf.high) |>
mutate(significativo = if_else(p.value < 0.05, "Sí", "No"))
