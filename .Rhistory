library(tidyverse)
library(broom) # Necesario para convertir los tests en tablas
resultados_t <- datosr |>
# 1. Reorganizar: creamos columnas 'pre', 'pos' y una que identifique la 'categoria'
pivot_longer(
cols = starts_with("pts_"),
names_to = c(".value", "categoria"),
names_pattern = "pts_(pre|pos)_(.*)"
)  |>
# 2. Agrupar por la categoría (vis, ana, abs)
group_by(categoria) |>
# 3. Aplicar la prueba T pareada y "limpiar" el resultado con tidy()
summarize(
test = list(t.test(pre, pos, paired = TRUE) |> tidy())
) |>
# 4. Desempaquetar los resultados para que queden en columnas legibles
unnest(test)
# Ver los resultados
print(resultados_t)
